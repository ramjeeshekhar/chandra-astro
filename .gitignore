############################
# Drupal runtime files 
# Modified to keept folder layout  
############################
/web/sites/*/files/*
!/web/sites/*/files/.gitkeep
/web/sites/*/private/

############################
# Environment-specific overrides
############################
/web/sites/*/settings.local.php
/web/sites/*/services.local.yml
/web/sites/*/settings.ddev.php

############################
